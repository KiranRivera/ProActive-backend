const express = require('express');
const router = express.Router();
const remindersController = require('../controllers/premium/remindersController');

// Rutas de Recordatorios Premium
router.get('/:userId', remindersController.getReminders);
router.post('/:userId', remindersController.createReminder);
router.patch('/:userId/:reminderId', remindersController.toggleReminder);
router.delete('/:userId/:reminderId', remindersController.deleteReminder);

module.exports = router;